---
const year = new Date().getFullYear()
---

<footer class="bg-yellow py-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-12">
      <!-- Brand -->
      <div>
        <a href="/" class="text-2xl font-bold text-navy tracking-tight">
          Merch<span class="text-sky">&</span>Move
        </a>
        <p class="text-sm text-indigo/70 mt-3 leading-relaxed">
          Your all-in-one partner for merchandising, active selling, and live software tracking.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-sm font-semibold text-navy mb-4">Quick Links</h3>
        <ul class="space-y-2.5">
          <li><a href="#" class="text-sm text-indigo/70 hover:text-navy transition-colors">Home</a></li>
          <li><a href="#merchandising" class="text-sm text-indigo/70 hover:text-navy transition-colors">Merchandising</a></li>
          <li><a href="#sales" class="text-sm text-indigo/70 hover:text-navy transition-colors">Sales</a></li>
          <li><a href="#platform" class="text-sm text-indigo/70 hover:text-navy transition-colors">Platform</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold text-navy mb-4">Contact</h3>
        <ul class="space-y-2.5">
          <li>
            <a href="mailto:info@merchandmove.co.za" class="text-sm text-indigo/70 hover:text-navy transition-colors flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
              info@merchandmove.co.za
            </a>
          </li>
          <li>
            <span class="text-sm text-indigo/70 flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
              Sandton, Johannesburg
            </span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Divider + Copyright -->
    <div class="border-t border-navy/20 pt-8">
      <p class="text-center text-xs text-gray-copy">
        &copy; {year} All rights Reserved, Merch and Move (PTY) LTD
      </p>
    </div>
  </div>
</footer>
